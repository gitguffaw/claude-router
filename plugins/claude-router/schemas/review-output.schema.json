{
  "type": "object",
  "required": ["verdict", "summary", "findings", "next_steps"],
  "additionalProperties": true,
  "properties": {
    "verdict": { "type": "string" },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "title", "body", "file"],
        "additionalProperties": true,
        "properties": {
          "severity": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "file": { "type": "string" },
          "line_start": { "type": ["integer", "null"] },
          "line_end": { "type": ["integer", "null"] },
          "recommendation": { "type": "string" }
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
